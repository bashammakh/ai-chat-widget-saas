# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
FILE_SEARCH_MAX_RESULTS=8

# --- Database (matches docker-compose service name "postgres") ---
DATABASE_URL=postgresql+psycopg2://chat:chat@postgres:5432/chatdb

# --- Admin dashboard (HTTP Basic auth) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# --- App ---
ENVIRONMENT=production
DEBUG=false
CONVERSATION_MEMORY_TURNS=10
# Public base URL for the embed snippet shown in admin (e.g. https://app.onrender.com).
# Leave empty to fall back to the current request host.
PUBLIC_BASE_URL=
# Directory the backend serves widget.js from (set on single-service deploys
# like Render). Leave empty when Nginx serves the widget (local docker-compose).
WIDGET_ASSETS_DIR=

# --- Security ---
ADMIN_ALLOWED_ORIGINS=*
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_DEFAULT=120/minute
